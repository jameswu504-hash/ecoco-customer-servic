# ECOCO AI customer service production environment template.
# Copy the keys into Render Environment Variables and fill company-owned values.
# Do not commit real secrets.

# Required production secrets.
DATABASE_URL=
ANTHROPIC_API_KEY=
ADMIN_KEY=

# Recommended production settings.
ANTHROPIC_MODEL=claude-sonnet-4-6
PGSSL=require
APP_MODE=customer
CONVERSATION_RETENTION_DAYS=180
KNOWLEDGE_AUTO_SYNC=disable

# Optional semantic RAG. Leave OPENAI_API_KEY empty to use keyword RAG fallback.
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_TIMEOUT_MS=10000

# LINE Official Account Messaging API.
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_RATE_LIMIT_MAX_EVENTS=8

# Internal wiki mode. Only set these if running a separate internal service.
STAFF_KEY=

# Only set to always for one deploy when intentionally rebuilding all chunks.
REBUILD_KNOWLEDGE_CHUNKS_ON_START=
