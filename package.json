{
  "name": "ecoco-customer-service",
  "version": "1.0.0",
  "description": "ECOCO AI customer service assistant",
  "main": "server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test tests/*.test.js",
    "lint": "node scripts/lint.mjs",
    "anonymize:pii": "node scripts/anonymize-pii.js",
    "scan:pii": "node scripts/scan-pii.js",
    "build:knowledge": "node scripts/build-ecoco-knowledge-data.js",
    "import:knowledge": "node scripts/import-knowledge-json.js",
    "audit:knowledge": "node scripts/audit-knowledge-quality.js",
    "apply:knowledge-audit": "node scripts/apply-knowledge-audit.js",
    "eval": "node scripts/run-evals.mjs",
    "eval:validate": "node scripts/run-evals.mjs --validate-only",
    "knowledge:drift": "node scripts/check-knowledge-drift.mjs",
    "suggest:synonyms": "node scripts/suggest-synonyms.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.104.1",
    "dotenv": "^16.0.0",
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^8.2.0",
    "mysql2": "^3.23.1",
    "nodemailer": "^9.0.3",
    "pg": "^8.21.0"
  }
}
