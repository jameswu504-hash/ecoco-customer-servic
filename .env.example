# Copy this file to .env and fill in the values.

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic model. Leave empty to use the server default.
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional semantic RAG search. If OPENAI_API_KEY is empty, the app falls back to keyword search.
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_TIMEOUT_MS=10000

# Optional live IoT station/machine lookup from readonly MySQL.
# Keep these in Render Environment Variables. Do not commit real passwords.
ECOCO_IOT_MYSQL_HOST=
ECOCO_IOT_MYSQL_PORT=3306
ECOCO_IOT_MYSQL_USER=
ECOCO_IOT_MYSQL_PASSWORD=
ECOCO_IOT_MYSQL_DATABASE=
ECOCO_IOT_MYSQL_SSL=true
ECOCO_IOT_MYSQL_SSL_REJECT_UNAUTHORIZED=true
ECOCO_IOT_MYSQL_CONNECTION_LIMIT=4
ECOCO_IOT_MYSQL_CONNECT_TIMEOUT_MS=10000
ECOCO_IOT_STATION_SNAPSHOT_PATH=

# Optional answer-quality evals.
# ECOCO_BASE_URL and ADMIN_KEY are usually stored in GitHub Actions secrets, not Render.
EVAL_MIN_PASS_RATE=0.85
EVAL_JUDGE_MODEL=
SYNONYM_SUGGEST_MODEL=

# LINE Official Account Messaging API.
# Keep empty until the company provides LINE Developers credentials.
# Webhook URL: https://<render-domain>/api/line/webhook
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_RATE_LIMIT_MAX_EVENTS=8
LINE_REPLY_TIMEOUT_MS=45000
LINE_TIMEOUT_REPLY=目前正在查詢資料，若問題需要人工確認，客服會再協助處理。

# PostgreSQL connection string, for example Neon / Supabase / Render Postgres.
DATABASE_URL=postgresql://user:password@host:5432/database

# Cloud Postgres usually needs SSL. Set PGSSL=disable only for trusted local or internal Render connections.
PGSSL=require

# Admin dashboard login key.
ADMIN_KEY=your-admin-key-here

# Service mode.
# customer: public customer-service website and dashboard.
# internal: enables /api/internal for staff wiki / training knowledge.
APP_MODE=customer
STAFF_KEY=

# Optional data retention. Suggested production value: 90 or 180.
# Aggregated reports still remain useful after old raw logs are removed.
CONVERSATION_RETENTION_DAYS=180

# Sync data/ecoco-knowledge-import.json into PostgreSQL when the server starts.
# disable: daily maintenance uses the dashboard/PostgreSQL only.
# insert_only: insert missing categories without overwriting dashboard edits.
# upsert: update matching categories and insert new ones.
# replace: delete existing knowledge_sections and re-import from JSON.
KNOWLEDGE_AUTO_SYNC=disable

# Optional. Set to always only when you intentionally want to rebuild all RAG chunks on startup.
# Normal production use should leave this empty.
REBUILD_KNOWLEDGE_CHUNKS_ON_START=

# Server port.
PORT=3000
