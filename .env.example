# Copy this file to .env and fill in the values.

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic model. Leave empty to use the server default.
ANTHROPIC_MODEL=claude-opus-4-7

# PostgreSQL connection string, for example Neon / Supabase / Render Postgres.
DATABASE_URL=postgresql://user:password@host:5432/database

# Cloud Postgres usually needs SSL. Set PGSSL=disable only for trusted local or internal Render connections.
PGSSL=require

# Admin dashboard login key.
ADMIN_KEY=your-admin-key-here

# Sync data/ecoco-knowledge-import.json into PostgreSQL when the server starts.
# enabled/upsert: update matching categories and insert new ones.
# replace: delete existing knowledge_sections and re-import from JSON.
# disable: do not sync on startup.
KNOWLEDGE_AUTO_SYNC=enabled

# Server port.
PORT=3000
